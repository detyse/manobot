{
  "$schema": "https://raw.githubusercontent.com/HKUDS/nanobot/main/schema.json",
  "agents": {
    "defaults": {
      "workspace": "~/.manobot/workspace",
      "model": "anthropic/claude-sonnet-4-20250514",
      "provider": "auto",
      "maxTokens": 8192,
      "temperature": 0.1,
      "maxToolIterations": 40,
      "memoryWindow": 100
    },
    "list": [
      {
        "id": "assistant",
        "default": true,
        "name": "Main Assistant",
        "identity": {
          "name": "Nano",
          "description": "A helpful AI assistant for general tasks"
        }
      },
      {
        "id": "coder",
        "name": "Code Assistant",
        "workspace": "~/projects",
        "model": "deepseek/deepseek-coder",
        "skills": ["coding", "git", "shell"],
        "identity": {
          "name": "CodeBot",
          "description": "Specialized coding assistant"
        },
        "subagents": {
          "allowAgents": ["reviewer"],
          "model": "deepseek/deepseek-chat"
        }
      },
      {
        "id": "reviewer",
        "name": "Code Reviewer",
        "model": "anthropic/claude-sonnet-4-20250514",
        "skills": ["coding"],
        "identity": {
          "name": "Reviewer",
          "description": "Code review specialist"
        }
      }
    ],
    "bindings": [
      {
        "agentId": "coder",
        "comment": "Route Telegram coding group to coder agent",
        "match": {
          "channel": "telegram",
          "peerType": "group",
          "peerId": "-100123456789"
        }
      },
      {
        "agentId": "coder",
        "comment": "Route Discord dev server to coder agent",
        "match": {
          "channel": "discord",
          "guildId": "987654321"
        }
      },
      {
        "agentId": "reviewer",
        "comment": "Route code review channel to reviewer",
        "match": {
          "channel": "slack",
          "peerType": "channel",
          "peerId": "C0123456789"
        }
      }
    ]
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "telegram": {
      "enabled": true,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "allowFrom": []
    },
    "discord": {
      "enabled": false,
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "allowFrom": []
    },
    "slack": {
      "enabled": false,
      "botToken": "xoxb-...",
      "appToken": "xapp-..."
    }
  },
  "providers": {
    "anthropic": {
      "apiKey": "YOUR_ANTHROPIC_API_KEY"
    },
    "deepseek": {
      "apiKey": "YOUR_DEEPSEEK_API_KEY"
    },
    "openrouter": {
      "apiKey": "YOUR_OPENROUTER_API_KEY"
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": true,
      "intervalS": 1800
    }
  },
  "tools": {
    "web": {
      "proxy": null,
      "search": {
        "apiKey": "",
        "maxResults": 5
      }
    },
    "exec": {
      "timeout": 60,
      "pathAppend": ""
    },
    "restrictToWorkspace": false,
    "mcpServers": {}
  }
}
